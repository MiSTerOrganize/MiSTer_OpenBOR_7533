# Normalize all text to LF on disk and in working tree (cross-platform).
# Prevents CRLF↔LF hash mismatches between CI-generated db.json.zip and
# raw.githubusercontent.com when update_all downloads to users.
# theypsilon (update_all dev) diagnosed this 2026-05-15 evening:
# "could be because github is outputing your files as text and they are
#  binaries or the other way around. In such case, the fix is through
#  git attributes in the source repository."
* text=auto eol=lf

# Binary artifacts — never normalize.
*.rbf binary
*.pak binary
*.bin binary
*.pin binary
*.jdi binary
*.sld binary

# ARM binary (no file extension — explicit path rule).
# IMPORTANT: must match the BUILD-SPECIFIC name `OpenBOR_7533`, NOT
# the legacy wildcard `games/*/OpenBOR` which silently failed to match
# and let git treat the binary as text — corrupting it on commit/checkout
# and breaking update_all hash validation. (Fixed 2026-05-16.)
games/OpenBOR/OpenBOR_7533 binary

# Shell scripts — keep LF
*.sh text eol=lf

# Python — keep LF
*.py text eol=lf

# Markdown — keep LF explicit (db.json hash consistency vs raw.githubusercontent.com)
*.md text eol=lf

# C / C++ / headers — text LF
*.c   text eol=lf
*.h   text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf

# SystemVerilog / Verilog — text LF
*.sv  text eol=lf
*.v   text eol=lf

# Quartus files — text LF
*.qpf text eol=lf
*.qsf text eol=lf
*.qip text eol=lf
*.sdc text eol=lf

# Quartus output summaries — text LF (small reports we commit)
*.summary text eol=lf
*.smsg    text eol=lf
